{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Interno UPLAB",
  "version": "0.1.1",
  "identifier": "com.uplab.interno",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "UPLAB · Módulos",
        "width": 440,
        "height": 640,
        "minWidth": 380,
        "minHeight": 520,
        "resizable": true,
        "center": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDREQkIzNEI2MzNCNzMyQzMKUldURE1yY3p0alM3VFFXRmxKZ2hqeEhPNjVRNzhJZGRHc2VZUVB2NkdjU05KRTdkQkZ2Z1Y3b3IK",
      "endpoints": [
        "https://github.com/UPLABINTERNO/UPLAB-INTERNO/releases/latest/download/latest.json"
      ]
    }
  }
}
